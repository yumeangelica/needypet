# NeedyPet client environment variables.
# Copy this file to .env.development and/or .env.production and fill in real values.
# Both of those files are gitignored.

# Base origin of the NeedyPet server. Leave empty when the client is served from
# the same origin as the server, or use a full origin in dev (e.g. http://localhost:3000).
# Do not include /api here; the client adds /auth and /api paths itself.
VITE_APP_BACKEND_URL=
