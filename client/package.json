{
  "name": "needypet-client",
  "private": true,
  "version": "2.2.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "rm -rf dist && rm -rf ../server/dist && vite build && cp -r dist ../server",
    "preview": "vite preview",
    "test:unit": "vitest",
    "lint": "biome lint src/",
    "lint:fix": "biome lint --write src/",
    "format": "biome format --write src/",
    "check": "biome check src/"
  },
  "dependencies": {
    "@lucide/vue": "^1.17.0",
    "@tailwindcss/vite": "^4.3.0",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.21",
    "pinia": "^3.0.4",
    "reka-ui": "^2.9.9",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "vue": "^3.5.35",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.3.4"
  },
  "description": "NeedyPet frontend client"
}
