{
  "name": "needypet-server",
  "version": "1.7.5",
  "description": "pet care management app",
  "main": "index.js",
  "scripts": {
    "start": "cross-env NODE_ENV=production node index.js",
    "dev": "cross-env NODE_ENV=development node --watch index.js",
    "test": "cross-env NODE_ENV=testing node --test --test-concurrency=1 __tests__/*.test.js",
    "test:coverage": "cross-env NODE_ENV=testing node --test --test-concurrency=1 --experimental-test-coverage __tests__/*.test.js",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "author": "yumeangelica",
  "license": "SEE LICENSE IN LICENSE",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "dayjs": "^1.11.19",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "jose": "^6.2.0",
    "mongoose": "^9.7.1",
    "node-cron": "^4.4.1",
    "nodemailer": "^9.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "supertest": "^7.2.2"
  }
}
