# Use node 22 as the base image (app runs on the Node runtime)
FROM node:22

# Install Bun, used only for dependency installation
RUN npm install -g bun

# Create app directory
WORKDIR /usr/src/app

# Copy package.json and the Bun lockfile if present
COPY package.json bun.lock* ./

# Install dependencies with Bun
RUN bun install

# Copy the rest of the application
COPY . .

# Build the application for production in port 5002
EXPOSE 5002

# Start the application (cross-env NODE_ENV=production node index.js)
CMD ["bun", "run", "start"]
